APP_NAME=my fastapi service
APP_VERSION=0.1.0
API_PREFIX=/api/v1
ENVIRONMENT=local
TIME_ZONE=Asia/Shanghai
LOG_LEVEL=INFO
DOCS_URL=/docs
OPENAPI_URL=/openapi.json
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_CREDENTIALS=false
DB_ENABLED=true
DB_GENERATE_SCHEMAS=false
DATABASE_URL=mysql://user:password@db:3306/database
EXTERNAL_REQUEST_TIMEOUT_SECONDS=20
